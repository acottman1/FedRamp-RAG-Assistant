# ── LLM Provider ──────────────────────────────────────────────────────────────
# Set to "openai" or "anthropic"
LLM_PROVIDER=openai

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Required for embeddings regardless of LLM_PROVIDER.
# Also required as the generator if LLM_PROVIDER=openai.
OPENAI_API_KEY=sk-...

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Only required if LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY=sk-ant-...

# ── Model selection ───────────────────────────────────────────────────────────
# Generator model name. Must match the chosen provider.
# OpenAI examples:   gpt-4o-mini  |  gpt-4o
# Anthropic examples: claude-3-5-haiku-20241022  |  claude-sonnet-4-6
LLM_MODEL=gpt-4o-mini

# Embedding model (always OpenAI)
EMBED_MODEL=text-embedding-3-small
